# Copy this file to .env and fill in ONE of the options below to enable
# LLM-generated narration. The system runs fully without either option
# (deterministic templated narration via MockChatClient).
#
# NEVER commit your actual .env file.

# ============================================================
# Option A: Azure OpenAI / Microsoft Foundry model deployment
# ============================================================
# Requires a model deployment with available quota in your
# Azure AI Foundry project (Models + Endpoints).
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01

# Alternative naming, matching the starter kit's .env template:
# AZURE_AI_PROJECT_ENDPOINT=your-project-endpoint-here
# AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# ============================================================
# Option B: GitHub Models (free, no Azure subscription/quota
# required -- recommended if you don't have Foundry model quota)
# ============================================================
# 1. Go to https://github.com/settings/tokens -> Generate new token
#    (fine-grained, no extra scopes needed for the free tier; or a
#    classic token also works).
# 2. Paste it below.
# GITHUB_MODELS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# ============================================================
# Microsoft Learn MCP Server (public knowledge augmentation)
# ============================================================
# Grounds the Learning Path Curator / Assessment / Study Plan agents in real
# Microsoft Learn docs, IN ADDITION to the synthetic knowledge base. This is
# PUBLIC content only -- it never mixes into the synthetic data/ records.
#
# Default is OFF: with LEARN_MCP_ENABLED unset/false the system runs on
# synthetic data only, fully functional. The endpoint is free and needs no
# auth. No secrets here.
#
LEARN_MCP_ENABLED=true
LEARN_MCP_ENDPOINT=https://learn.microsoft.com/api/mcp
LEARN_MCP_MAX_TOKEN_BUDGET=4000      # caps response size (cost control)
LEARN_MCP_CACHE_TTL_HOURS=24         # Learn refreshes ~daily; 24h is safe
